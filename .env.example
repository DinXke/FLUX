# SmartMarstek Standalone Docker Configuration
# Copy this file to .env and customize values

# ─────────────────────────────────────────────────────────────────────────
# InfluxDB Configuration
# ─────────────────────────────────────────────────────────────────────────
INFLUX_USERNAME=marstek
INFLUX_PASSWORD=marstek2024!
INFLUX_ORG=marstek
INFLUX_BUCKET=energy
INFLUX_TOKEN=marstek-influx-token-local
INFLUX_RETENTION=0
INFLUX_URL=http://influxdb:8086

# ─────────────────────────────────────────────────────────────────────────
# Grafana Configuration
# ─────────────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin2024!

# ─────────────────────────────────────────────────────────────────────────
# Energy Market Data (Optional)
# ─────────────────────────────────────────────────────────────────────────
ENTSOE_API_KEY=
ENTSOE_COUNTRY=BE

# ─────────────────────────────────────────────────────────────────────────
# AI Models (Optional, for autonomous strategy)
# ─────────────────────────────────────────────────────────────────────────
CLAUDE_API_KEY=
OPENAI_API_KEY=

# ─────────────────────────────────────────────────────────────────────────
# Notifications (Optional)
# ─────────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─────────────────────────────────────────────────────────────────────────
# Hardware Integration
# ─────────────────────────────────────────────────────────────────────────
# SMA Inverter (Modbus TCP)
SMA_IP=192.168.1.100
SMA_PORT=502

# HomeWizard Energy Meter
HOMEWIZARD_IP=

# Frank Energie API
FRANK_ENERGIE_API_KEY=

# ─────────────────────────────────────────────────────────────────────────
# Climate Control (Optional, Fase 2)
# ─────────────────────────────────────────────────────────────────────────
DAIKIN_TOKEN=
BOSCH_TOKEN=

# ─────────────────────────────────────────────────────────────────────────
# System Configuration
# ─────────────────────────────────────────────────────────────────────────
TIMEZONE=Europe/Brussels
LOG_LEVEL=info

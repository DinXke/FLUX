# FLUX — Flexible Local Utility eXchange
# Kopieer dit bestand naar .env en vul de waarden in.
# De install.sh wizard genereert dit bestand automatisch.
# Secrets (FLASK_SECRET_KEY, INFLUX_TOKEN, ...) worden automatisch gegenereerd.

# ─────────────────────────────────────────────────────────────────────────
# FLUX Standalone
# ─────────────────────────────────────────────────────────────────────────
STANDALONE_MODE=true
TIMEZONE=Europe/Brussels
LOG_LEVEL=info

# Flask sessie-encryptie — genereer met: openssl rand -hex 32
FLASK_SECRET_KEY=

# ─────────────────────────────────────────────────────────────────────────
# InfluxDB
# ─────────────────────────────────────────────────────────────────────────
INFLUX_URL=http://influxdb:8086
INFLUX_USERNAME=flux
INFLUX_PASSWORD=
INFLUX_ORG=flux
INFLUX_BUCKET=energy
INFLUX_TOKEN=
INFLUX_RETENTION=0

# ─────────────────────────────────────────────────────────────────────────
# Grafana
# ─────────────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────
# Authenticatie (admin + readonly gebruikers)
# AUTH_ENABLED=true beschermt alle /api/auth/* en /api/users/* endpoints met JWT
# Default false = alle API endpoints toegankelijk zonder token (dev only)
# ─────────────────────────────────────────────────────────────────────────
AUTH_ENABLED=true
FLUX_ADMIN_USER=admin
FLUX_ADMIN_PASSWORD=
JWT_EXPIRY_HOURS=24

# ─────────────────────────────────────────────────────────────────────────
# Energieprijzen (ENTSO-E)
# ─────────────────────────────────────────────────────────────────────────
ENTSOE_API_KEY=
ENTSOE_COUNTRY=BE

# ─────────────────────────────────────────────────────────────────────────
# AI providers (optioneel)
# ─────────────────────────────────────────────────────────────────────────
CLAUDE_API_KEY=
OPENAI_API_KEY=

# ─────────────────────────────────────────────────────────────────────────
# Telegram notificaties (optioneel)
# ─────────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─────────────────────────────────────────────────────────────────────────
# Hardware integratie
# ─────────────────────────────────────────────────────────────────────────
# SMA Omvormer (Modbus TCP)
SMA_IP=
SMA_PORT=502

# HomeWizard energiemeter
HOMEWIZARD_IP=

# Frank Energie
FRANK_ENERGIE_API_KEY=

# ─────────────────────────────────────────────────────────────────────────
# Klimaatregeling (optioneel, Fase 2)
# ─────────────────────────────────────────────────────────────────────────
DAIKIN_TOKEN=
BOSCH_TOKEN=

# ─────────────────────────────────────────────────────────────────────────
# Home Assistant integratie (optioneel, standaard uitgeschakeld)
# ─────────────────────────────────────────────────────────────────────────
HA_INTEGRATION_ENABLED=false
HA_URL=
HA_TOKEN=

# FLUX — Flexible Local Utility eXchange
# Kopieer dit bestand naar .env en vul de waarden in.
# De install.sh wizard genereert dit bestand automatisch.
# Secrets (FLASK_SECRET_KEY, INFLUX_TOKEN, ...) worden automatisch gegenereerd.

# ─────────────────────────────────────────────────────────────────────────
# FLUX Standalone
# ─────────────────────────────────────────────────────────────────────────
STANDALONE_MODE=true
TIMEZONE=Europe/Brussels
LOG_LEVEL=info

# Flask sessie-encryptie — genereer met: openssl rand -hex 32
FLASK_SECRET_KEY=

# ─────────────────────────────────────────────────────────────────────────
# InfluxDB
# ─────────────────────────────────────────────────────────────────────────
INFLUX_URL=http://influxdb:8086
INFLUX_USERNAME=flux
INFLUX_PASSWORD=
INFLUX_ORG=flux
INFLUX_BUCKET=energy
INFLUX_TOKEN=
INFLUX_RETENTION=0

# ─────────────────────────────────────────────────────────────────────────
# Grafana
# ─────────────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
# Verplicht: Grafana URL zoals bereikbaar vanuit de browser (MET trailing slash)
# Bv: GRAFANA_EXTERNAL_URL=https://10.10.30.112/grafana/
# Of met eigen domein: GRAFANA_EXTERNAL_URL=https://grafana.jouwdomein.com/grafana/
# Zonder deze var valt Grafana terug op hostname-detectie (resolvet naar localhost)
GRAFANA_EXTERNAL_URL=

# ─────────────────────────────────────────────────────────────────────────
# Authenticatie (admin + readonly gebruikers)
# AUTH_ENABLED=true beschermt alle /api/auth/* en /api/users/* endpoints met JWT
# Default false = alle API endpoints toegankelijk zonder token (dev only)
# ─────────────────────────────────────────────────────────────────────────
AUTH_ENABLED=true
FLUX_ADMIN_USER=admin
FLUX_ADMIN_PASSWORD=
JWT_EXPIRY_HOURS=24

# ─────────────────────────────────────────────────────────────────────────
# Energieprijzen (ENTSO-E)
# ─────────────────────────────────────────────────────────────────────────
ENTSOE_API_KEY=
ENTSOE_COUNTRY=BE

# ─────────────────────────────────────────────────────────────────────────
# AI providers (optioneel)
# ─────────────────────────────────────────────────────────────────────────
CLAUDE_API_KEY=
OPENAI_API_KEY=

# ─────────────────────────────────────────────────────────────────────────
# Telegram notificaties (optioneel)
# ─────────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─────────────────────────────────────────────────────────────────────────
# Hardware integratie
# ─────────────────────────────────────────────────────────────────────────
# SMA Omvormer (Modbus TCP)
SMA_IP=
SMA_PORT=502

# HomeWizard energiemeter
HOMEWIZARD_IP=

# Frank Energie
FRANK_ENERGIE_API_KEY=

# ─────────────────────────────────────────────────────────────────────────
# Klimaatregeling (optioneel, Fase 2)
# ─────────────────────────────────────────────────────────────────────────
DAIKIN_TOKEN=
BOSCH_TOKEN=

# ─────────────────────────────────────────────────────────────────────────
# Bosch Home Connect cloud API (huishoudapparaten: wasmachine, vaatwasser, etc.)
# Registreer een app op https://developer.home-connect.com/
# ─────────────────────────────────────────────────────────────────────────
BOSCH_APPLIANCES_CLIENT_ID=
BOSCH_APPLIANCES_CLIENT_SECRET=
# Gebruik je Cloudflare/HTTPS domein (geen IP of poort):
BOSCH_APPLIANCES_REDIRECT_URI=https://jouw-flux-domein.nl/api/bosch-appliances/callback
# Lokaal zonder reverse proxy:
# BOSCH_APPLIANCES_REDIRECT_URI=http://192.168.1.x:5000/api/bosch-appliances/callback
# BOSCH_APPLIANCES_SANDBOX=true   # schakel in voor simulator (geen echt apparaat nodig)

# ─────────────────────────────────────────────────────────────────────────
# Home Assistant integratie (optioneel, standaard uitgeschakeld)
# ─────────────────────────────────────────────────────────────────────────
HA_INTEGRATION_ENABLED=false
HA_URL=
HA_TOKEN=

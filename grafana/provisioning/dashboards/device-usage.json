          "query": "import \"math\"\n\nfrom(bucket: \"flux\")\n  |> range(start: -24h)\n  |> filter(fn: (r) => r._measurement == \"device_power\")\n  |> filter(fn: (r) => r.device_label == \"${device_label}\")\n  |> filter(fn: (r) => r._field == \"power_w\")\n  |> aggregateWindow(every: 30s, fn: max)\n  |> filter(fn: (r) => r._value > 50)\n  |> reduce(fn: (r, accumulator) => ({\n      count: accumulator.count + 1\n    }), initial: {count: 0})\n  |> map(fn: (r) => ({r with _value: r.count}))\n  |> yield(name: \"cycle_count\")"

          "refId": "A",
          "query": "import \"math\"\n\n// Count cycles: transitions where power goes from <50W to >50W\nfrom(bucket: \"flux\")\n  |> range(start: -7d)\n  |> filter(fn: (r) => r._measurement == \"device_power\")\n  |> filter(fn: (r) => r.device_label == \"${device_label}\")\n  |> filter(fn: (r) => r._field == \"energy_kwh_delta\")\n  |> sum()\n  |> yield(name: \"total_energy\")\n\nfrom(bucket: \"flux\")\n  |> range(start: -7d)\n  |> filter(fn: (r) => r._measurement == \"device_power\")\n  |> filter(fn: (r) => r.device_label == \"${device_label}\")\n  |> filter(fn: (r) => r._field == \"power_w\")\n  |> aggregateWindow(every: 30s, fn: max)\n  |> filter(fn: (r) => r._value > 50)\n  |> reduce(fn: (r, accumulator) => ({\n      count: accumulator.count + 1\n    }), initial: {count: 0})\n  |> yield(name: \"cycle_count\")"
        }
      ],
      "title": "Gemiddeld verbruik per cyclus",
      "type": "stat"

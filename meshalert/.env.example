# CoreScope WebSocket URL
CORESCOPE_WS_URL=ws://192.168.1.1:8765

# Telegram notificaties (optioneel)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Pubkey-prefixen om te bewaken (komma-gescheiden)
WATCH_PUBKEYS=fc1c4b,DinX-EDG,JZH.H39

# Minimale tijd tussen Telegram-alerts per node (minuten)
ALERT_COOLDOWN_MINUTES=5

# Service poort
PORT=7842

# Data directory (SQLite + repeaters.json)
DATA_DIR=/app/data
